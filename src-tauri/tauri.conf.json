{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dimkey",
  "version": "0.8.0",
  "identifier": "com.dimkey.cn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Dimkey",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://dimkey.com/latest-zh.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1QjgwMEE2NjM5N0RGQTkKUldTcDM1ZGpwZ0M0dFdWWDdyc3pQbEhDYldhYmJxbncwdU43Z2VTanNNc1NLaTZvVkpqMWhCdXoK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["app", "dmg", "nsis"],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Developer ID Application: zeshun tan (2GDQYR464F)"
    },
    "resources": {
      "resources/ner/*": "ner/",
      "resources/pdfium/*": "pdfium/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
